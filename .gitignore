# ----------------------------------------------------------------------
# Emacs Default Ignore Rules
# ----------------------------------------------------------------------

# 1. Package Management (Don't commit installed packages)
/elpa/
/eln-cache/
/straight/

# 2. Temporary & Backup Files
*~
\#*\#
.#*
*.tmp
*.log
/tmp/

# 3. Emacs Auto-generated Files
/auto-save-list/
/transient/
/var/
/.org-id-locations
*_archive
/ac-comphist.dat
/recentf
/history
/server/
/image-dired/
.ido.last

# 4. LSP & Tree-sitter (Local & Binary files)
.lsp-session*
/tree-sitter/

# 5. Compiled Byte-code
*.elc

# 6. OS Specific
.DS_Store
Thumbs.db

# 7. Custom Settings
# custom.el