# ----------------------------------------------------------------------
# Emacs Default Ignore Rules
# ----------------------------------------------------------------------

# 1. Package Management (Don't commit installed packages)
/elpa/
/eln-cache/
/straight/

# 2. Temporary & Backup Files
*~
\#*\#
.#*
*.tmp
*.log
/tmp/

# 3. Emacs Auto-generated Files
/auto-save-list/
/transient/
/var/
/.org-id-locations
*_archive
/ac-comphist.dat
/recentf
/history
/server/
/image-dired/
.ido.last

# 4. Compiled Byte-code (Optional: keep if you want to verify compilation)
*.elc

# 5. OS Specific
.DS_Store
Thumbs.db

# 6. Custom Settings
# It is often recommended to ignore custom.el if it contains machine-specific
# paths or sensitive data. If you want to sync it, comment out the line below.
# custom.el